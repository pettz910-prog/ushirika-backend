# ─── Database ────────────────────────────────────────────────────────────────
# Railway provides DATABASE_URL automatically when you attach a PostgreSQL plugin
DATABASE_URL=jdbc:postgresql://localhost:5432/ushirika_db
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=yourpassword
DB_POOL_SIZE=10

# ─── JPA ─────────────────────────────────────────────────────────────────────
# "update" lets Hibernate auto-create/alter tables from entities
DDL_AUTO=update

# ─── JWT ─────────────────────────────────────────────────────────────────────
# Minimum 256-bit random secret — generate: openssl rand -hex 32
JWT_SECRET=replace_with_long_random_secret_min_32_chars
JWT_ACCESS_EXPIRY=900000
JWT_REFRESH_EXPIRY=604800000

# ─── Superadmin seed (first boot only) ───────────────────────────────────────
SUPERADMIN_EMAIL=admin@ushirikawelfare.org
SUPERADMIN_PASSWORD=ChangeMe@2025!
SUPERADMIN_PHONE=+254700000000

# ─── Brevo (transactional email) ─────────────────────────────────────────────
BREVO_API_KEY=xkeysib-...
BREVO_SENDER_EMAIL=noreply@ushirikawelfare.org
BREVO_SENDER_NAME=Ushirika Welfare

# ─── Africa's Talking (SMS) ──────────────────────────────────────────────────
AT_API_KEY=atsk_...
AT_USERNAME=your_africastalking_username
AT_SENDER_ID=USHIRIKA

# ─── Cloudinary (media uploads) ──────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ─── Paystack (payments) ─────────────────────────────────────────────────────
PAYSTACK_SECRET_KEY=sk_live_...
PAYSTACK_PUBLIC_KEY=pk_live_...

# ─── CORS ────────────────────────────────────────────────────────────────────
CORS_ORIGINS=https://yourfrontend.com,https://www.ushirikawelfare.org

# ─── Swagger UI ──────────────────────────────────────────────────────────────
SWAGGER_ENABLED=true

# ─── Rate limiting (requests per minute per IP) ───────────────────────────────
RATE_LIMIT_AUTH_RPM=10
RATE_LIMIT_PUBLIC_RPM=60
RATE_LIMIT_API_RPM=120

# ─── Logging ─────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
SHOW_SQL=false

# ─── Server — Railway injects PORT automatically, do not set on Railway ───────
PORT=8080
